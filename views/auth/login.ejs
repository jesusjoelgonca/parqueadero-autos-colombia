<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión - Autos Colombia</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root {
      --ac-primary: #0a5f7a;
      --ac-primary-dark: #084c61;
      --ac-primary-light: #e0f2f5;
      --ac-danger: #dc2626;
    }
    body { background-color: #e9ecef; }
    .login-card { max-width: 420px; border: none; border-radius: 4px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid var(--ac-primary); }
    .login-header { background: var(--ac-primary); color: #fff; padding: 1rem 1.25rem; }
    .login-header h1 { font-size: 1.35rem; font-weight: 600; margin: 0; letter-spacing: 0.02em; }
    .login-header p { font-size: 0.85rem; margin: 0.2rem 0 0; opacity: 0.95; }
    .login-body { background: #fff; padding: 1.5rem 1.75rem; }
    .login-title { font-size: 1.25rem; font-weight: 600; color: #212529; margin-bottom: 0.25rem; }
    .login-subtitle { font-size: 0.875rem; color: #6c757d; margin-bottom: 1.25rem; }
    .form-label { font-size: 0.75rem; font-weight: 600; color: #212529; text-transform: uppercase; letter-spacing: 0.03em; }
    .form-control { border: 1px solid #ced4da; border-radius: 4px; }
    .form-control:focus { border-color: var(--ac-primary); box-shadow: 0 0 0 0.2rem rgba(10, 95, 122, 0.25); }
    .password-wrap { position: relative; }
    .password-wrap .form-control { padding-right: 4rem; }
    .btn-toggle-pwd { position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: #6c757d; font-size: 0.8rem; text-decoration: underline; cursor: pointer; padding: 0; }
    .btn-toggle-pwd:hover { color: var(--ac-primary); }
    .forgot-link { font-size: 0.875rem; text-decoration: underline; color: var(--ac-primary); }
    .forgot-link:hover { color: var(--ac-primary-dark); }
    .btn-ingresar { background: var(--ac-primary); color: #fff; border: none; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.6rem 1rem; width: 100%; border-radius: 4px; }
    .btn-ingresar:hover { background: var(--ac-primary-dark); color: #fff; }
    .msg-box { background: var(--ac-primary-light); border: 1px solid rgba(10, 95, 122, 0.2); border-radius: 4px; padding: 0.6rem 0.75rem; font-size: 0.875rem; color: #0c4a6e; margin-top: 1rem; }
    .msg-box.alert-danger { background: #f8d7da; border-color: #f5c2c7; color: #842029; }
    .login-footer { background: #fff; padding: 0.75rem 1.75rem; font-size: 0.8rem; color: #6c757d; border-top: 1px solid #eee; }
  </style>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100">
  <div class="card login-card w-100">
    <div class="login-header">
      <h1>AUTOS COLOMBIA</h1>
      <p>Sistema de Parqueadero</p>
    </div>
    <div class="login-body">
      <h2 class="login-title">Iniciar Sesión</h2>
      <p class="login-subtitle">Ingresa tus credenciales para acceder al sistema</p>
      <form action="/auth/login" method="post" id="formLogin">
        <div class="mb-3">
          <label for="correo" class="form-label">Correo electrónico</label>
          <input type="email" id="correo" name="correo" class="form-control" placeholder="Ej. operador@autoscolombia.com" required autofocus autocomplete="email">
        </div>
        <div class="mb-2">
          <label for="password" class="form-label">Contraseña</label>
          <div class="password-wrap">
            <input type="password" id="password" name="password" class="form-control" required autocomplete="current-password">
            <button type="button" class="btn-toggle-pwd" id="togglePwd" aria-label="Mostrar u ocultar contraseña">[ ver ]</button>
          </div>
        </div>
        <div class="text-end mb-3">
          <a href="#" class="forgot-link">¿Olvidé mi contraseña?</a>
        </div>
        <button type="submit" class="btn btn-ingresar">Ingresar</button>
      </form>
      <div class="msg-box <%= typeof error !== 'undefined' && error ? 'alert-danger' : '' %>" id="msgBox">
        <% if (typeof error !== 'undefined' && error) { %>
          <%= error %>
        <% } else { %>
          Acceso restringido — Solo personal autorizado
        <% } %>
      </div>
    </div>
    <div class="login-footer text-center">
      Parqueadero Autos Colombia © 2026
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function () {
      var pwd = document.getElementById('password');
      var toggle = document.getElementById('togglePwd');
      if (pwd && toggle) {
        toggle.addEventListener('click', function () {
          var isPassword = pwd.type === 'password';
          pwd.type = isPassword ? 'text' : 'password';
          toggle.textContent = isPassword ? '[ ocultar ]' : '[ ver ]';
        });
      }
    })();
  </script>
</body>
</html>
