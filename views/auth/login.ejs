<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Autos Colombia</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root { --ac-primary: #0a5f7a; --ac-primary-light: #e0f2f5; }
    .brand-ac { color: #0a5f7a !important; }
    .btn-ac { background: #0a5f7a; border-color: #0a5f7a; color: #fff; }
    .btn-ac:hover { background: #084c61; border-color: #084c61; color: #fff; }
    .card-ac { border-left: 4px solid #0a5f7a; }
  </style>
</head>
<body class="bg-light d-flex align-items-center justify-content-center min-vh-100">
  <div class="card shadow card-ac" style="width: 320px;">
    <div class="card-body">
      <h5 class="card-title text-center brand-ac">AUTOS COLOMBIA</h5>
      <p class="text-center small text-muted">Sistema de Parqueadero</p>
      <form action="/auth/login" method="post">
        <div class="mb-2">
          <label class="form-label">Usuario</label>
          <input type="text" name="login" class="form-control" required autofocus>
        </div>
        <div class="mb-3">
          <label class="form-label">Contraseña</label>
          <input type="password" name="password" class="form-control" required>
        </div>
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger py-2"><%= error %></div>
        <% } %>
        <button type="submit" class="btn btn-ac w-100">Entrar</button>
      </form>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
