<%- include('../partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, active: typeof active !== 'undefined' ? active : '' }) %>

<section class="mb-4">
  <h6 class="fw-bold text-dark">Busqueda de Vehiculo</h6>
  <p class="text-muted small mb-0">Ingrese el numero de placa para verificar si el vehiculo se encuentra dentro del parqueadero.</p>
</section>

<div class="card border border-secondary bg-white shadow-sm mb-4 card-ac">
  <div class="card-body">
    <h6 class="text-dark small fw-bold mb-2">BUSCAR POR PLACA</h6>
    <form action="/busqueda" method="get" class="row g-2 align-items-end">
      <div class="col-auto flex-grow-1">
        <label class="form-label text-muted small fw-bold mb-0">NUMERO DE PLACA</label>
        <input type="text" name="placa" class="form-control form-control-sm border-secondary" placeholder="Ej: ABC-123" value="<%= typeof placa !== 'undefined' ? placa : '' %>">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-ac btn-sm">BUSCAR</button>
      </div>
    </form>
  </div>
</div>

<% if (typeof placa !== 'undefined' && placa) { %>
  <% if (vehiculo) { %>
  <div class="mb-3">
    <p class="small text-muted fw-bold mb-2">ESCENARIO 1: VEHICULO ENCONTRADO</p>
    <div class="card border border-secondary bg-white shadow-sm position-relative card-ac">
      <div class="card-body">
        <span class="badge badge-disponible text-white position-absolute top-0 end-0 m-2">EN PARQUEADERO</span>
        <h6 class="text-dark fw-bold mb-3">Vehiculo Encontrado</h6>
        <div class="row">
          <div class="col-md-6">
            <p class="small text-muted mb-0">PLACA</p>
            <p class="mb-2 text-dark"><%= vehiculo.placa %></p>
            <p class="small text-muted mb-0">HORA DE ENTRADA</p>
            <p class="mb-0 text-dark"><%= vehiculo.hora_entrada %></p>
          </div>
          <div class="col-md-6">
            <p class="small text-muted mb-0">TIPO DE VEHICULO</p>
            <p class="mb-2"><span class="badge <%= vehiculo.tipo_vehiculo === 'Carro' ? 'badge-carro' : 'badge-moto' %> text-white"><%= vehiculo.tipo_vehiculo %></span></p>
            <p class="small text-muted mb-0">FECHA DE ENTRADA</p>
            <p class="mb-2 text-dark"><%= typeof vehiculo.fecha_entrada_formato !== 'undefined' ? vehiculo.fecha_entrada_formato : vehiculo.fecha_entrada %></p>
            <p class="small text-muted mb-0">CELDA ASIGNADA</p>
            <p class="mb-2"><span class="badge badge-ac text-white"><%= vehiculo.numero_celda %></span></p>
            <p class="small text-muted mb-0">PROPIETARIO</p>
            <p class="mb-0 text-dark"><%= vehiculo.nombre_propietario %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } else { %>
  <div class="mb-3">
    <p class="small text-muted fw-bold mb-2">ESCENARIO 2: VEHICULO NO ENCONTRADO</p>
    <div class="card border border-secondary bg-white shadow-sm">
      <div class="card-body text-center py-4">
        <p class="display-6 text-danger mb-2" aria-hidden="true">[X]</p>
        <p class="text-danger mb-0">No se encontro ningun vehiculo con esa placa. Verifique el numero de placa e intente nuevamente.</p>
      </div>
    </div>
  </div>
  <% } %>
<% } %>

<%- include('../partials/footer') %>
