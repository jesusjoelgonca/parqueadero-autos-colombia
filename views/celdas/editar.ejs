<%- include('../partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, active: typeof active !== 'undefined' ? active : '' }) %>

<section class="mb-4">
  <h6 class="fw-bold text-dark">Editar Celda</h6>
  <p class="text-muted small mb-0">Modifique el tipo o el estado de la celda. Solo puede desactivar una celda que esté disponible.</p>
</section>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-danger border border-danger mb-3" role="alert"><%= error %></div>
<% } %>

<form action="/celdas/editar/<%= celda.id_celda %>" method="post" class="mb-4">
  <div class="card border border-secondary bg-white shadow-sm card-ac">
    <div class="card-header py-2">
      <strong>CELDA <%= celda.numero_celda %></strong>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label text-dark small fw-bold">NÚMERO DE CELDA</label>
          <input type="text" class="form-control form-control-sm border-secondary bg-light" value="<%= celda.numero_celda %>" readonly>
        </div>
        <div class="col-md-6">
          <label class="form-label text-dark small fw-bold">TIPO <span class="text-danger">*</span></label>
          <select name="tipo_celda" class="form-select form-select-sm border-secondary" required>
            <option value="Carro" <%= celda.tipo_celda === 'Carro' ? 'selected' : '' %>>Carro</option>
            <option value="Moto" <%= celda.tipo_celda === 'Moto' ? 'selected' : '' %>>Moto</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label text-dark small fw-bold">ESTADO <span class="text-danger">*</span></label>
          <select name="estado" class="form-select form-select-sm border-secondary" required>
            <option value="Disponible" <%= celda.estado === 'Disponible' ? 'selected' : '' %>>Disponible</option>
            <option value="Ocupada" <%= celda.estado === 'Ocupada' ? 'selected' : '' %>>Ocupada</option>
            <option value="Inactiva" <%= celda.estado === 'Inactiva' ? 'selected' : '' %> <%= celda.estado === 'Ocupada' ? 'disabled' : '' %>>Inactiva</option>
          </select>
          <% if (celda.estado === 'Ocupada') { %>
          <p class="small text-muted mt-1 mb-0">Para desactivar esta celda, primero registre la salida del vehículo.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-ac">GUARDAR</button>
    <a href="/celdas" class="btn btn-outline-secondary border-2">CANCELAR</a>
  </div>
</form>

<%- include('../partials/footer') %>
