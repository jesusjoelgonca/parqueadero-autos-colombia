<%- include('../partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, active: typeof active !== 'undefined' ? active : '' }) %>

<section class="mb-3 d-flex flex-wrap align-items-center gap-2">
  <p class="text-muted small mb-0">Visualiza y administra el estado de cada celda del parqueadero.</p>
  <a href="/celdas/reporte" class="btn btn-outline-primary btn-sm">Ver reporte de ocupación</a>
</section>

<% if (typeof mensaje !== 'undefined' && mensaje) { %>
<div class="alert alert-success border border-success mb-3" role="alert"><%= mensaje %></div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-danger border border-danger mb-3" role="alert"><%= error %></div>
<% } %>

<div class="card border border-secondary bg-white shadow-sm mb-3 card-ac">
  <div class="card-body">
    <form action="/celdas" method="get" class="row g-2 align-items-end flex-wrap">
      <div class="col-auto">
        <label class="form-label text-dark small fw-bold mb-0">FILTRAR POR TIPO</label>
        <select name="tipo" class="form-select form-select-sm border-secondary" style="min-width: 120px;">
          <option value="" <%= (typeof filtroTipo !== 'undefined' && filtroTipo === 'Todos') ? 'selected' : '' %>>Todos</option>
          <option value="Carro" <%= (typeof filtroTipo !== 'undefined' && filtroTipo === 'Carro') ? 'selected' : '' %>>Carro</option>
          <option value="Moto" <%= (typeof filtroTipo !== 'undefined' && filtroTipo === 'Moto') ? 'selected' : '' %>>Moto</option>
        </select>
      </div>
      <div class="col-auto">
        <label class="form-label text-dark small fw-bold mb-0">FILTRAR POR ESTADO</label>
        <select name="estado" class="form-select form-select-sm border-secondary" style="min-width: 120px;">
          <option value="" <%= (typeof filtroEstado !== 'undefined' && filtroEstado === 'Todos') ? 'selected' : '' %>>Todos</option>
          <option value="Disponible" <%= (typeof filtroEstado !== 'undefined' && filtroEstado === 'Disponible') ? 'selected' : '' %>>Disponible</option>
          <option value="Ocupada" <%= (typeof filtroEstado !== 'undefined' && filtroEstado === 'Ocupada') ? 'selected' : '' %>>Ocupada</option>
          <option value="Inactiva" <%= (typeof filtroEstado !== 'undefined' && filtroEstado === 'Inactiva') ? 'selected' : '' %>>Inactiva</option>
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-ac btn-sm">FILTRAR</button>
      </div>
      <% if (typeof user !== 'undefined' && user && user.rol === 'Administrador') { %>
      <div class="col-auto ms-md-auto">
        <a href="/celdas/nueva" class="btn btn-ac btn-sm">+ NUEVA CELDA</a>
      </div>
      <% } %>
    </form>
  </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-2 small text-muted">
  <span class="d-flex align-items-center"><span class="badge badge-disponible text-white me-1">Disponible</span></span>
  <span class="d-flex align-items-center"><span class="badge badge-ocupada-celda text-white me-1">Ocupada</span></span>
  <span class="d-flex align-items-center"><span class="badge badge-inactiva text-white me-1">Inactiva</span></span>
</div>

<div class="card border border-secondary bg-white shadow-sm mb-3 card-ac">
  <div class="card-body">
    <div class="row g-2" id="gridCeldas">
      <% if (typeof celdas !== 'undefined' && celdas.length > 0) { celdas.forEach(function(c) {
        var bg = c.estado === 'Disponible' ? 'bg-success bg-opacity-10 border-success' : (c.estado === 'Ocupada' ? 'bg-danger bg-opacity-10 border-danger' : 'bg-secondary bg-opacity-10 border-secondary');
        var badge = c.estado === 'Disponible' ? 'badge-disponible' : (c.estado === 'Ocupada' ? 'badge-ocupada-celda' : 'badge-inactiva');
      %>
      <div class="col-4 col-md-2">
        <div class="celda-item border rounded p-2 text-center <%= bg %>" data-id="<%= c.id_celda %>" data-estado="<%= c.estado %>" data-numero="<%= c.numero_celda %>" style="cursor: pointer; min-height: 70px;">
          <span class="fw-bold d-block"><%= c.numero_celda %></span>
          <span class="badge <%= badge %> text-white" style="font-size: 0.7rem;"><%= c.estado %></span>
          <span class="d-block small text-muted"><%= c.tipo_celda %></span>
        </div>
      </div>
      <% }); } else { %>
      <div class="col-12 text-muted text-center py-4">No hay celdas que coincidan con el filtro.</div>
      <% } %>
    </div>

    <% if (typeof user !== 'undefined' && user && user.rol === 'Administrador' && typeof celdas !== 'undefined' && celdas.length > 0) { %>
    <div class="mt-3 pt-3 border-top d-flex flex-wrap gap-2 align-items-center" id="accionesCelda" style="display: none !important;">
      <span class="text-muted small" id="celdaSeleccionadaLabel"></span>
      <a href="#" class="btn btn-ac btn-sm" id="btnGestionar">GESTIONAR CELDA</a>
      <button type="button" class="btn btn-outline-danger btn-sm" id="btnDesactivar" data-bs-toggle="modal" data-bs-target="#modalDesactivar" style="display: none;">DESACTIVAR</button>
      <button type="button" class="btn btn-outline-secondary btn-sm" id="btnCancelarSel">CANCELAR</button>
    </div>
    <% } %>
  </div>
</div>

<div class="row g-2 mb-4">
  <div class="col-6 col-md-3">
    <div class="card border border-secondary bg-white shadow-sm">
      <div class="card-body py-2 text-center">
        <span class="d-block fw-bold text-dark"><%= typeof total !== 'undefined' ? total : 0 %></span>
        <span class="small text-muted">TOTAL CELDAS</span>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border border-success bg-white shadow-sm">
      <div class="card-body py-2 text-center">
        <span class="d-block fw-bold text-success"><%= typeof disponibles !== 'undefined' ? disponibles : 0 %></span>
        <span class="small text-muted">DISPONIBLES</span>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border border-danger bg-white shadow-sm">
      <div class="card-body py-2 text-center">
        <span class="d-block fw-bold text-danger"><%= typeof ocupadas !== 'undefined' ? ocupadas : 0 %></span>
        <span class="small text-muted">OCUPADAS</span>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border border-secondary bg-white shadow-sm">
      <div class="card-body py-2 text-center">
        <span class="d-block fw-bold text-secondary"><%= typeof inactivas !== 'undefined' ? inactivas : 0 %></span>
        <span class="small text-muted">INACTIVAS</span>
      </div>
    </div>
  </div>
</div>

<% if (typeof user !== 'undefined' && user && user.rol === 'Administrador') { %>
<!-- Modal confirmar desactivar -->
<div class="modal fade" id="modalDesactivar" tabindex="-1" aria-labelledby="modalDesactivarLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalDesactivarLabel">Confirmar desactivar celda</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">¿Está seguro de desactivar la celda <strong id="modalCeldaNumero"></strong>? No aparecerá como disponible en el módulo de entradas hasta que la reactive.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <form action="#" method="post" id="formDesactivar" class="d-inline">
          <input type="hidden" name="_method" value="post">
          <button type="submit" class="btn btn-ac">Desactivar</button>
        </form>
      </div>
    </div>
  </div>
</div>
<% } %>

<script>
(function() {
  var acciones = document.getElementById('accionesCelda');
  var label = document.getElementById('celdaSeleccionadaLabel');
  var btnGestionar = document.getElementById('btnGestionar');
  var btnCancelar = document.getElementById('btnCancelarSel');
  var celdaSeleccionada = null;

  function deseleccionar() {
    celdaSeleccionada = null;
    if (acciones) acciones.style.display = 'none';
    document.querySelectorAll('.celda-item').forEach(function(el) { el.classList.remove('border-3'); });
  }

  document.querySelectorAll('.celda-item').forEach(function(el) {
    el.addEventListener('click', function() {
      var id = this.getAttribute('data-id');
      var numero = this.getAttribute('data-numero');
      var estado = this.getAttribute('data-estado');
      if (!id) return;
      document.querySelectorAll('.celda-item').forEach(function(c) { c.classList.remove('border-3'); });
      this.classList.add('border-3');
      celdaSeleccionada = { id: id, numero: numero, estado: estado };
      if (label) label.textContent = 'Celda seleccionada: ' + numero;
      if (btnGestionar) {
        btnGestionar.href = '/celdas/editar/' + id;
        btnGestionar.style.display = 'inline-block';
      }
      var btnDesactivar = document.getElementById('btnDesactivar');
      if (btnDesactivar) {
        btnDesactivar.style.display = estado === 'Disponible' ? 'inline-block' : 'none';
        btnDesactivar.setAttribute('data-celda-id', id);
        btnDesactivar.setAttribute('data-celda-numero', numero);
      }
      if (acciones) acciones.style.display = 'flex';
    });
  });

  if (btnCancelar) btnCancelar.addEventListener('click', deseleccionar);

  var modalDesactivar = document.getElementById('modalDesactivar');
  var formDesactivar = document.getElementById('formDesactivar');
  var modalCeldaNumero = document.getElementById('modalCeldaNumero');
  if (modalDesactivar && formDesactivar && modalCeldaNumero) {
    modalDesactivar.addEventListener('show.bs.modal', function(ev) {
      var btn = ev.relatedTarget;
      var id = btn && btn.getAttribute('data-celda-id');
      var numero = btn && btn.getAttribute('data-celda-numero');
      if (id && numero) {
        modalCeldaNumero.textContent = numero;
        formDesactivar.action = '/celdas/' + id + '/desactivar';
      }
    });
  }
})();
</script>

<%- include('../partials/footer') %>
