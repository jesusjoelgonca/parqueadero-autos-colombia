<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Parqueadero' %> - Autos Colombia</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container-fluid">
    <div class="row">
      <nav class="col-md-2 bg-dark text-white min-vh-100 py-3">
        <div class="px-3">
          <h5 class="text-white">AUTOS COLOMBIA</h5>
          <p class="small text-secondary">Sistema de Parqueadero</p>
        </div>
        <ul class="nav flex-column">
          <li class="nav-item"><a class="nav-link text-white <%= (active === 'entrada') ? 'bg-secondary' : '' %>" href="/entrada/registrar">Registrar Entrada</a></li>
          <li class="nav-item"><a class="nav-link text-white <%= (active === 'salida') ? 'bg-secondary' : '' %>" href="/salida/registrar">Registrar Salida</a></li>
          <li class="nav-item"><a class="nav-link text-white <%= (active === 'estacionados') ? 'bg-secondary' : '' %>" href="/estacionados">Vehículos Estacionados</a></li>
          <li class="nav-item"><a class="nav-link text-white <%= (active === 'busqueda') ? 'bg-secondary' : '' %>" href="/busqueda">Buscar Vehículo</a></li>
          <li class="nav-item"><a class="nav-link text-white <%= (active === 'historial') ? 'bg-secondary' : '' %>" href="/historial">Historial</a></li>
        </ul>
        <hr class="border-secondary">
        <form action="/auth/logout" method="post" class="px-3">
          <button type="submit" class="btn btn-outline-light btn-sm">Cerrar sesión</button>
        </form>
      </nav>
      <main class="col-md-10 py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="h3"><%= typeof title !== 'undefined' ? title : 'Parqueadero' %></h1>
          <% if (typeof user !== 'undefined' && user) { %>
          <span class="text-muted">Usuario: <%= user.rol %></span>
          <% } %>
        </div>
        <%- body %>
      </main>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
