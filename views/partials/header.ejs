<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Parqueadero' %> - Autos Colombia</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root {
      --ac-primary: #0a5f7a;
      --ac-primary-light: #e0f2f5;
      --ac-success: #0d9488;
      --ac-success-bg: #ccfbf1;
      --ac-danger: #dc2626;
      --ac-info: #0284c7;
      --ac-info-bg: #e0f2fe;
    }
    .nav-ac .nav-link.active { background: var(--ac-primary-light) !important; color: var(--ac-primary) !important; border-left: 3px solid var(--ac-primary); font-weight: 600; }
    .nav-ac .nav-link:hover:not(.active) { background: #f8f9fa; }
    .brand-ac { color: var(--ac-primary) !important; }
    .card-ac { border-left: 4px solid var(--ac-primary); }
    .card-ac .card-header { background: var(--ac-primary-light) !important; border-bottom-color: var(--ac-primary) !important; color: #0c4a6e; font-weight: 600; }
    .btn-ac { background: var(--ac-primary); border-color: var(--ac-primary); color: #fff; }
    .btn-ac:hover { background: #084c61; border-color: #084c61; color: #fff; }
    .badge-ac { background: var(--ac-primary); }
    .badge-disponible { background: var(--ac-success); }
    .badge-ocupada { background: #64748b; }
    .badge-ocupada-celda { background: var(--ac-danger); }
    .badge-inactiva { background: #6b7280; }
    .badge-carro { background: var(--ac-primary); }
    .badge-moto { background: var(--ac-info); }
    .pagination .page-item.active .page-link { background: var(--ac-primary); border-color: var(--ac-primary); }
  </style>
</head>
<body class="bg-light">
<div class="container-fluid">
  <div class="row">
    <%- include('nav', { active: typeof active !== 'undefined' ? active : '', user: typeof user !== 'undefined' ? user : null }) %>
    <main class="col-md-10 py-4 bg-light">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0 text-dark"><%= typeof title !== 'undefined' ? title : '' %></h1>
        <% if (typeof user !== 'undefined' && user) { %><span class="badge badge-ac px-3 py-2">Usuario: <%= user.rol %></span><% } %>
      </div>
